{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TourManager",
  "version": "1.0.7",
  "identifier": "com.myfilestour.com",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TourManager",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AuchGit/CSVTourManager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGQzM3QTBBRjcxRENDMDIKUldRQ3pCMzNDbnJEdnpUR1B3amdkWUZxQXNESHExUUpySE9ob3pxUjBPbTdFdFB2WDZmWXhQak0K"
    }
  }
}
